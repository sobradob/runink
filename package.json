{
  "name": "runink",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preprocess": "tsx scripts/preprocess-garmin.ts",
    "server": "tsx watch server/index.ts",
    "server:prod": "NODE_ENV=production node --import tsx server/index.ts",
    "start": "NODE_ENV=production node --import tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/s3-request-presigner": "^3.1015.0",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@garmin/fitsdk": "^21.195.0",
    "@mapbox/polyline": "^1.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "maplibre-gl": "^5.21.0",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "resend": "^6.10.0",
    "stripe": "^20.4.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "yauzl": "^3.2.1"
  }
}
